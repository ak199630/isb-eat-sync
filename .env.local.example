# Supabase (required for Sprint 1 DB)
# Create a project at https://supabase.com, then run the SQL files in schema/ in order.
# Get URL and keys from: Project Settings → API (Project URL, anon/public key).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for "I'm leaving" and vendor fulfill-by-QR API
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enable Realtime for live sold-out/status updates
# In Supabase Dashboard: Database → Replication → enable for tables: stalls, menu_items
